      "post": {
        "tags": [
          "Ticket"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CommentModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CommentModel"
